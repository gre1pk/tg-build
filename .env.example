# false = каталог/портфолио из /api (Supabase); true = mock-данные в браузере
VITE_USE_MOCK_DATA=false

# В npm run dev mock-auth включён по умолчанию (POST /api/auth/dev, только локально).
# Отключить для проверки реального initData: VITE_USE_MOCK_AUTH=false
# ID mock-пользователя — совпадай с ADMIN_TELEGRAM_IDS для теста админки
VITE_MOCK_TELEGRAM_ID=123456789

# Server-only (Vercel + локальный .env — не коммитить)
TELEGRAM_BOT_TOKEN=
AUTH_JWT_SECRET=

# Supabase — Dashboard → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin — см. docs/ADMIN.md
ADMIN_TELEGRAM_IDS=123456789

VITE_REACT_APP_VERSION=
