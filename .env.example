# false = каталог/портфолио из /api (Supabase); true = mock-данные в браузере
VITE_USE_MOCK_DATA=false

# Telegram @username мастера для кнопки «Задать вопрос» (без @). Пусто или невалидно = кнопка скрыта.
VITE_MASTER_TELEGRAM_USERNAME=

# В npm run dev mock-auth включён по умолчанию (POST /api/auth/dev, только локально).
# Отключить для проверки реального initData: VITE_USE_MOCK_AUTH=false
# ID mock-пользователя — совпадай с ADMIN_TELEGRAM_IDS или MASTER_TELEGRAM_IDS для теста staff
VITE_MOCK_TELEGRAM_ID=123456789

# Server-only (Vercel + локальный .env — не коммитить)
TELEGRAM_BOT_TOKEN=
AUTH_JWT_SECRET=

# Supabase — Dashboard → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin / staff — см. docs/ADMIN.md (полный доступ к /admin и /api/admin/*)
ADMIN_TELEGRAM_IDS=123456789

# Мастер студии — те же права, role=master в /api/admin/me (не путать с MASTER_TELEGRAM_CHAT_ID)
MASTER_TELEGRAM_IDS=

# P3: уведомление мастера о новой заявке (numeric chat id, не username, не auth)
MASTER_TELEGRAM_CHAT_ID=

# P3: базовый URL Mini App для ссылки в bot notify (без trailing slash)
APP_BASE_URL=https://tg-build-ivory.vercel.app

VITE_REACT_APP_VERSION=
